# Telegram Bot Token
# Obtain this from @BotFather on Telegram after creating a new bot.
# Command: /newbot
# This value is sensitive. Never commit the real value to version control.
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# User Timezone for the Nightly Cron Job
# Must be a valid IANA timezone string.
# Examples: America/New_York, Europe/London, Asia/Kolkata, Asia/Singapore
# This must match the timezone the user provides during the onboarding conversation.
# After onboarding, check the user's stored profile and set this value to match.
USER_TIMEZONE=Asia/Kolkata
